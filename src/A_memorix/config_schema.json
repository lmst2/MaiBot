          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 1,
          "hint": "相对路径按 MaiBot 仓库根目录解析，建议保持默认外置目录。",
          "placeholder": "data/a-memorix",
          "choices": null
        }
      }
    },
    "embedding": {
      "name": "embedding",
      "title": "Embedding",
      "description": "控制向量写入与检索的核心嵌入配置。",
      "icon": null,
      "collapsed": false,
      "order": 3,
      "fields": {
        "model_name": {
          "name": "model_name",
          "type": "string",
          "default": "auto",
          "description": "Embedding 模型选择",
          "label": "模型选择",
          "ui_type": "text",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 1,
          "hint": "默认 auto，会按宿主环境自动选择可用 embedding 模型。",
          "placeholder": "auto",
          "choices": null
        },
        "dimension": {
          "name": "dimension",
          "type": "integer",
          "default": 1024,
          "description": "向量维度",
          "label": "向量维度",
          "ui_type": "number",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 2,
          "hint": "唯一公开维度控制项，修改后建议先执行 runtime self-check。",
          "min": 1,
          "max": 32768,
          "step": 1,
          "choices": null
        },
        "batch_size": {
          "name": "batch_size",
          "type": "integer",
          "default": 32,
          "description": "单批请求大小",
          "label": "批大小",
          "ui_type": "number",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 3,
          "hint": "批量过大可能放大模型或网络波动。",
          "min": 1,
          "max": 1024,
          "step": 1,
          "choices": null
        },
        "max_concurrent": {
          "name": "max_concurrent",
          "type": "integer",
          "default": 5,
          "description": "最大并发数",
          "label": "最大并发",
          "ui_type": "number",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 4,
          "hint": "用于限制并行 embedding 请求数量。",
          "min": 1,
          "max": 128,
          "step": 1,
          "choices": null
        },
        "enable_cache": {
          "name": "enable_cache",
          "type": "boolean",
          "default": false,
          "description": "是否启用缓存",
          "label": "启用向量缓存",
          "ui_type": "switch",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 5,
          "hint": "适合重复写入较多的场景，默认关闭以保持路径更直观。",
          "choices": null
        },
        "quantization_type": {
          "name": "quantization_type",
          "type": "string",
          "default": "int8",
          "description": "量化方式",
          "label": "量化方式",
          "ui_type": "select",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 6,
          "hint": "当前 vNext 主路径仅支持 int8(SQ8)。",
          "choices": [
            "int8"
          ]
        }
      }
    },
