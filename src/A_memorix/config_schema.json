{
  "plugin_id": "a_memorix",
  "plugin_info": {
    "name": "A_Memorix",
    "version": "2.0.0",
    "description": "长期记忆与认知增强子系统，支持常用配置可视化与原始 TOML 兜底编辑。",
    "author": "A_Dawn"
  },
  "_note": "未在本 Schema 展示的高级键仍然有效，请通过源码模式或原始 TOML 编辑。",
  "layout": {
    "type": "tabs",
    "tabs": [
      {
        "id": "basic",
        "title": "基础",
        "sections": [
          "plugin",
          "storage",
          "embedding"
        ],
        "order": 1
      },
      {
        "id": "stability",
        "title": "稳定性",
        "sections": [
          "embedding.fallback",
          "embedding.paragraph_vector_backfill"
        ],
        "order": 2
      },
      {
        "id": "retrieval",
        "title": "检索",
        "sections": [
          "retrieval",
          "retrieval.sparse",
          "threshold",
          "filter"
        ],
        "order": 3
      },
      {
        "id": "memory",
        "title": "记忆",
        "sections": [
          "episode",
          "person_profile",
          "memory"
        ],
        "order": 4
      },
      {
        "id": "operations",
        "title": "运维",
        "sections": [
          "advanced",
          "web.import",
          "web.tuning"
        ],
        "order": 5
      }
    ]
  },
  "sections": {
    "plugin": {
      "name": "plugin",
      "title": "子系统状态",
      "description": "控制 A_Memorix 是否在宿主中启用。",
      "icon": null,
      "collapsed": false,
      "order": 1,
      "fields": {
        "enabled": {
          "name": "enabled",
          "type": "boolean",
          "default": true,
          "description": "是否启用 A_Memorix",
          "label": "启用 A_Memorix",
          "ui_type": "switch",
          "required": false,
          "hidden": false,
          "disabled": false,
          "order": 1,
          "hint": "关闭后 A_Memorix 不会参与长期记忆写入、检索与运维。",
          "choices": null
        }
      }
    },
    "storage": {
      "name": "storage",
      "title": "存储位置",
      "description": "控制 A_Memorix 的运行数据目录。",
